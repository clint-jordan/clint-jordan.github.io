---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getConfigurationCollection, getBaseUrl } from "../../lib/utils";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const { data: config } = await getConfigurationCollection();
  const baseUrl = await getBaseUrl();
  
  return posts.map((article) => ({
    params: { id: article.data.slug },
    props: { 
      article: {
        ...article,
        data: {
          ...article.data,
          url: `${baseUrl}/blog/${article.data.slug}`,
        },
      },
    },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<BlogLayout frontmatter={article.data}>
  <Content />
</BlogLayout>
