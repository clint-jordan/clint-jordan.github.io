---
import Layout from "../layouts/Layout.astro";
import { getConfigurationCollection, getBaseUrl } from "../lib/utils";

const { data: config } = await getConfigurationCollection();
const baseUrl = await getBaseUrl();
---

<Layout>
  <Fragment slot="head">
    <title>{config.notFoundMeta.title}</title>
    <meta
      name="description"
      content={config.notFoundMeta.longDescription ?? config.notFoundMeta.description}
    />
    <meta property="og:title" content={config.notFoundMeta.title} />
    <meta
      property="og:description"
      content={config.notFoundMeta.description}
    />
    {config.notFoundMeta.keywords && (
      <meta name="keywords" content={config.notFoundMeta.keywords.join(", ")} />
    )}
    {config.notFoundMeta.cardImage && (
      <meta property="og:image" content={config.notFoundMeta.cardImage} />
    )}
    <meta property="og:url" content={baseUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={config.notFoundMeta.title} />
    <meta
      name="twitter:description"
      content={config.notFoundMeta.description}
    />
    {config.notFoundMeta.cardImage && (
      <meta name="twitter:image" content={config.notFoundMeta.cardImage} />
    )}
    <meta http-equiv="content-language" content="en" />
    <meta name="language" content="English" />
    <link rel="canonical" href={baseUrl} />
  </Fragment>
  <div class="flex flex-col items-center justify-center min-h-[60vh]">
    <h1 class="text-6xl font-bold mb-4">404</h1>
    <p class="text-xl mb-8">{config.notFoundMeta.description}</p>
    <a href="/" class="text-blue-500 hover:text-blue-700 underline">
      Go back home
    </a>
  </div>
</Layout>
